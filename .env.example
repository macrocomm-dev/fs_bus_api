# ---------------------------------------------------------------------------
# .env.example — copy to .env and fill in local overrides.
#
# Values left empty here are fetched from GCloud Secret Manager at startup
# (requires: gcloud auth application-default login).
# ---------------------------------------------------------------------------

# GCloud project that hosts Secret Manager secrets and Cloud SQL.
GOOGLE_CLOUD_PROJECT=bus_track

# Cloud SQL instance connection name used by the proxy / start.sh.
# Format: <project>:<region>:<instance>
CLOUD_SQL_INSTANCE=bus_track:us-central1:fs-bus-db

# Database connection.
# DB_HOST defaults to 127.0.0.1 when running via the proxy locally.
DB_HOST=127.0.0.1
DB_PORT=5432

# The following secrets are loaded from Secret Manager when left empty.
# You may set them here for local convenience (do NOT commit to git).
DB_NAME=
DB_USER=
DB_PASSWORD=
SECRET_KEY=

# OAuth2 / JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — comma-separated list of allowed origins.
# Set to "*" for local development only (not recommended for production).
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API listen port (start.sh)
API_PORT=8000
